{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CancelCommand",
  "type": "object",
  "required": [
    "schemaVersion",
    "messageId",
    "correlationId",
    "pipelineRunId",
    "jobExecutionId",
    "reason",
    "requestedBy",
    "gracePeriodSeconds",
    "requestedAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "messageId": {
      "type": "string",
      "format": "uuid"
    },
    "correlationId": {
      "type": "string",
      "format": "uuid"
    },
    "pipelineRunId": {
      "type": "string",
      "format": "uuid"
    },
    "jobExecutionId": {
      "type": "string",
      "format": "uuid"
    },
    "reason": {
      "type": "string"
    },
    "requestedBy": {
      "type": "string"
    },
    "gracePeriodSeconds": {
      "type": "integer",
      "minimum": 1
    },
    "requestedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}