# Локальные параметры docker-compose.
# Значения ниже являются placeholders для разработки и не являются реальными секретами.

COMPOSE_PROJECT_NAME=fuzzing-ci-cd-local

KAFKA_IMAGE=apache/kafka:3.9.1
KAFKA_HOST_PORT=9092
KAFKA_ADVERTISED_HOST=localhost
KAFKA_CLUSTER_ID=4L6g3nShT-eMCtK--X86sw
KAFKA_TOPIC_PARTITIONS=1

KAFKA_UI_IMAGE=ghcr.io/kafbat/kafka-ui:v1.4.2
KAFKA_UI_HOST_PORT=8080
KAFKA_UI_CLUSTER_NAME=local
KAFKA_UI_BOOTSTRAP_SERVERS=kafka:19092

# Пустое значение оставляет локальные логи человекочитаемыми.
# Для deploy-конфигурации используйте logstash.
LOGGING_STRUCTURED_FORMAT_CONSOLE=

CICD_STORAGE_LOCAL_ROOT=/tmp/cicd-storage-service

OPENSEARCH_IMAGE=opensearchproject/opensearch:2.19.3
OPENSEARCH_HOST_PORT=9200
OPENSEARCH_PERFORMANCE_HOST_PORT=9600
OPENSEARCH_HEAP=512m

POSTGRES_IMAGE=postgres:16.13-alpine3.23
POSTGRES_HOST_PORT=5432
POSTGRES_DB=cicd_master_contract
POSTGRES_USER=cicd_local
POSTGRES_PASSWORD=local-postgres-password

MINIO_IMAGE=minio/minio:RELEASE.2025-09-07T16-13-09Z
MINIO_MC_IMAGE=minio/mc:RELEASE.2025-08-13T08-35-41Z
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
MINIO_ROOT_USER=cicd-local-minio
MINIO_ROOT_PASSWORD=local-minio-password
MINIO_DEFAULT_BUCKET=cicd-artifacts
